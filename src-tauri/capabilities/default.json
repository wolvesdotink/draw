{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",
    "dialog:allow-open",
    "updater:default",
    "process:default",
    "process:allow-restart",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/drawings" },
        { "path": "$APPDATA/drawings/**" },
        { "path": "$APPDATA/state.json" }
      ]
    }
  ]
}
