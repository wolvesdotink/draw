{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "draw",
  "version": "0.1.0",
  "identifier": "ink.wolves.draw",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "draw",
        "width": 1200,
        "height": 800,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "GraphicsAndDesign",
    "shortDescription": "Local-first Excalidraw desktop app.",
    "longDescription": "draw is a brutalist, local-first desktop app for Excalidraw. Drawings live as plain .excalidraw files in ~/Library/Application Support, autosaved continuously, with full offline support.",
    "copyright": "Copyright (c) 2026 Wolves Software. All rights reserved.",
    "publisher": "Wolves Software",
    "homepage": "https://wolves.ink",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "appPosition": { "x": 180, "y": 220 },
        "applicationFolderPosition": { "x": 480, "y": 220 },
        "windowSize": { "width": 660, "height": 420 }
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2MkE1NkYxODI1M0ZGNUQKUldSZC8xT0M4VllxZHZ2czlBL2tkOEwwSWNtVXdQQ0NtS2hieUZUUnF4MVBoM05CbzEzbklRZ3EK",
      "endpoints": [
        "https://github.com/wolvessoftware/draw/releases/latest/download/latest.json"
      ]
    }
  }
}
